---
import AppLayout from "@/layout/AppLayout.astro";
import MainLayout from "@/layout/MainLayout.astro";
import { searchByQuery } from "@/lib/getData";
import {imagesUrl} from "@/lib/constant";
import {slugify} from "@/lib/helper";

const { searchParams } = Astro.url;
const query = searchParams.get("query") || "";

let tvData = []
let movieData = []
let errors = { tv: null, movie: null };

const [tvResult, movieResult] = await Promise.allSettled([
    searchByQuery({ mediaType: "tv", query }),
    searchByQuery({ mediaType: "movie", query }),
]);

if (tvResult.status === "fulfilled") {
    tvData = tvResult.value;
} else {
    errors.tv = tvResult.reason.message;
}

if (movieResult.status === "fulfilled") {
    movieData = movieResult.value;
} else {
    errors.movie = movieResult.reason.message;
}

---
<AppLayout>
    <title slot="head">Search Results for {query} | Alfath Muqoddas MovieApp</title>
    <MainLayout>
        <h1 class="text-3xl font-bold my-8 px-6 md:px-0">Search Results for <i>{query}</i></h1>

        <section class="px-6 md:px-0 mb-8">
			<h1 class="text-xl md:text-3xl font-bold">Movies Results</h1>
			<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 mt-2 border-t border-l">
				{
					errors.movie ? <>Error</> : movieData.length === 0 ? <>No Results</> : movieData.map((movie: any) => (
						<a href={"/details/movie/" + slugify(movie.title) + "-" + movie.id} class="bg-white p-2 border-b border-r border-black group flex items-center gap-2">
							<figure class="basis-1/6 md:basis-1/4 grow-0">
								<img width="92" height="auto" src={movie.poster_path ? imagesUrl + "w92" + movie.poster_path : "https://placehold.co/96x96?text=No+Data"} alt={"poster-" + slugify(movie.title)} class="w-full h-full object-cover" />
							</figure>
							<div class="basis-5/6 md:basis-3/4 grow-0">
							<h3 class="font-bold text-sm group-hover:underline group-hover:underline-offset-2">{movie.title}</h3>
							<p class="text-xs">{movie.release_date.slice(0,4)}</p>
							</div>
						</a>
					))
				}
			</div>
		</section>
    	<section class="px-6 md:px-0">
			<h1 class="text-xl md:text-3xl font-bold">TV Shows Results</h1>
			<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 mt-2 border-t border-l">
				{
					errors.tv ? <>Error</> : tvData.lenght === 0 ? <>No Results</> : tvData.map((tv: any) => (
						<a href={"/details/tv/" + slugify(tv.name) + "-" + tv.id} class="bg-white p-2 border-b border-r border-black group flex items-center gap-2">
							<figure class="basis-1/6 md:basis-1/4 grow-0">
								<img width="92" height="auto" src={tv.poster_path ? imagesUrl + "w92" + tv.poster_path : "https://placehold.co/96x96?text=No+Data"} alt={"poster-" + slugify(tv.name)} class="w-full h-full object-cover" />
							</figure>
							<div class="basis-5/6 md:basis-3/4 grow-0">
							<h3 class="font-bold text-sm group-hover:underline group-hover:underline-offset-2">{tv.name}</h3>
							<p class="text-xs">{tv.first_air_date.slice(0,4)}</p>
							</div>
						</a>
					))
				}
			</div>
		</section>
    </MainLayout>
</AppLayout>
