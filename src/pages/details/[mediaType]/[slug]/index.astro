---
import AppLayout from "@/layout/AppLayout.astro";
import MainLayout from "@/layout/MainLayout.astro";
import { getMediaDetails, getCreditData, getPicsData, getVideosData, getSimilarData, getCelebData  } from "@/lib/getData";
import {imagesUrl} from "@/lib/constant";
import {extractSlug, convertMinutesToHM, formatDateToMonthYear, slugify} from "@/lib/helper";

const { mediaType, slug } = Astro.params;


if (!mediaType || !slug) {
  return Astro.redirect('/404');
}

if (mediaType !== 'movie' && mediaType !== 'tv') {
  return Astro.redirect('/404');
}

const id = extractSlug(slug);

let mediaDetails = [];
let credit = [];
let pics = [];
let videos = [];
let similar = [];
let error = { mediaDetails: null, credit: null, pics: null, videos: null, similar: null };



const [mediaDetailsResult, creditResult, picsResult, videosResult, similarResult] = await Promise.allSettled([
    getMediaDetails(mediaType, id),
    getCreditData(mediaType, id),
    getPicsData(mediaType, id),
    getVideosData(mediaType, id),
    getSimilarData(mediaType, id),
]);

if (mediaDetailsResult.status === "fulfilled") {
    mediaDetails = mediaDetailsResult.value;
} else {
    error.mediaDetails = mediaDetailsResult.reason.message;
}

if (creditResult.status === "fulfilled") {
    credit = creditResult.value;
} else {
    error.credit = creditResult.reason.message;
}

if (picsResult.status === "fulfilled") {
    pics = picsResult.value;
} else {
    error.pics = picsResult.reason.message;
}

if (videosResult.status === "fulfilled") {
    videos = videosResult.value;
} else {
    error.videos = videosResult.reason.message;
}

if (similarResult.status === "fulfilled") {
    similar = similarResult.value;
} else {
    error.similar = similarResult.reason.message;
}

const importantCrews = credit?.crew?.filter((crew: any) => crew.job === "Director" || crew.job === "Producer" || crew.job === "Screenplay" || crew.job === "Writer");
---
<AppLayout>
    <title slot="head">{mediaDetails.title || mediaDetails.name} | Alfath Muqoddas MovieApp</title>
    <!-- opengraph meta -->
    <meta property="og:title" content={mediaDetails.title || mediaDetails.name + " | Alfath Muqoddas | MovieApp"} slot="head" />
    <meta property="og:type" content="article" slot="head" />
    <meta property="og:description" content={mediaDetails.overview + " " + "Alfath Muqoddas | MovieApp"} slot="head" />
    <meta property="og:image" content={imagesUrl + "w300" + mediaDetails.poster_path} slot="head"/>
    <meta property="og:url" content={Astro.url.href} slot="head" />
    <!-- twitter meta -->
    <meta name="twitter:card" content="summary_large_image" slot="head" />
    <meta name="twitter:title" content={mediaDetails.title || mediaDetails.name + " | Alfath Muqoddas | MovieApp"} slot="head"/>
    <meta name="twitter:description" content={mediaDetails.overview + " " + "Alfath Muqoddas | MovieApp"} slot="head"/>
    <meta name="twitter:image" content={imagesUrl + "w300" + mediaDetails.poster_path} slot="head"/>
    <meta name="twitter:url" content={Astro.url.href} slot="head"/>
    <MainLayout>
        <section class="flex flex-col gap-6 md:gap-8">

        <section>
            <figure class="h-120 relative overflow-hidden">
                <img 
                    src={imagesUrl + "w1280" + mediaDetails.backdrop_path} 
                    alt={mediaDetails.title || mediaDetails.name}
                    class="w-full h-full object-cover"
                    width="1280"
                    height="720"
                />

                <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/80 to-transparent flex flex-col justify-end p-6 md:p-4">
                    <div class="flex flex-col md:flex-row gap-6 items-center mx-auto h-full min-h-0 overflow-hidden">
                        <figure class="shrink rounded-2xl border-2 border-white/10 overflow-hidden min-h-0 max-h-full">
                            <img src={imagesUrl + "w185" + mediaDetails.poster_path} class="w-auto h-full object-containe" width="185" height="auto" />
                        </figure>
                        <div class="flex flex-col flex-1 min-h-0 overflow-y-auto gap-2">
                            <div class="flex flex-wrap gap-1">
                            {mediaDetails.genres.map((genre: any) => (
                                <span class="text-xs uppercase text-white bg-zinc-600/60 rounded-full px-4 py-1">{genre.name}</span>
                            ))}
                            </div>
                            <h1 class="text-white text-3xl md:text-5xl">
                                {mediaDetails.title || mediaDetails.name}
                            </h1>
                            <div class="flex gap-2 items-center flex-wrap">
                                <span class="text-sm text-white rounded-full px-3 py-1 bg-zinc-600/60">
                                    📅 {formatDateToMonthYear(mediaDetails.release_date || mediaDetails.first_air_date)}
                                </span>
                                <span class={`${mediaDetails.vote_average < 6 ? "bg-red-500/60 text-white" : mediaDetails.vote_average >= 6 && mediaDetails.vote_average <= 7 ? "bg-amber-200/90" : "bg-green-500/70 text-white"} text-sm rounded-full px-3 py-1`}>
                                    ★ {mediaDetails.vote_average.toFixed(1)}
                                </span>
                                {mediaType === "movie" && (
                                <span class="text-sm text-white px-3 py-1 rounded-full bg-zinc-600/60">
                                    ⏰ {convertMinutesToHM(mediaDetails.runtime)}
                                </span>)}
                            </div>
                            
                        </div>
                    </div>
                </div>
            </figure>
        </section>
        <section class="max-md:mx-6">
            <h1 class="text-2xl font-black">Overview</h1>
            <p class="text-sm text-muted-foreground text-justify">{mediaDetails.overview}</p>
        </section>
        <section class="">
            <h1 class="text-2xl font-black max-md:mx-6">Cast</h1>
            {error.credit ? <>Error fetching cast data</> : (
            <div class="max-w-6xl overflow-auto flex gap-2 py-2 px-6 md:px-0">
                {
                    credit.cast.map((cast: any) => (
                        <div class="w-24 flex flex-col gap-2">
                            <figure class="w-24 h-24 rounded-full overflow-hidden">
                                <img loading="lazy" src={cast.profile_path ? imagesUrl + "w185" + cast.profile_path : "https://placehold.co/96x96?text=No+Data"} class="w-full h-full object-cover" width="185" height="auto" />
                            </figure>
                            <div class="">
                                <h3 class="font-bold text-sm group-hover:underline group-hover:underline-offset-2">{cast.name}</h3>
                                <p class="text-xs">{cast.character}</p>
                            </div>
                        </div>
                    ))
                }
            </div>)}
        </section>
        <section class="">
            <h1 class="text-2xl font-black max-md:mx-6">Crews</h1>
            {error.credit ? <>Error fetching cast data</> : (
            <div class="max-w-6xl overflow-auto flex gap-2 py-2 px-6 md:px-0">
                {
                    importantCrews.map((cast: any) => (
                        <div class="w-24 flex flex-col gap-2">
                            <figure class="w-24 h-24 rounded-full overflow-hidden">
                                <img loading="lazy" src={cast.profile_path ? imagesUrl + "w185" + cast.profile_path : "https://placehold.co/96x96?text=No+Data"} class="w-full h-full object-cover" width="185" height="auto" />
                            </figure>
                            <div class="">
                                <h3 class="font-bold text-sm group-hover:underline group-hover:underline-offset-2">{cast.name}</h3>
                                <p class="text-xs">{cast.job}</p>
                            </div>
                        </div>
                    ))
                }
            </div>)}
        </section>
        <section class="">
            <h1 class="text-2xl font-black max-md:mx-6">Videos</h1>
            {error.videos ? <>Error fetching videos data</> : (
            <div class="max-w-6xl overflow-auto flex gap-2 py-2 px-6 md:px-0">
                {
                    videos.map((video: any) => (
                        <a class="flex flex-col gap-2 group cursor-pointer" href={"https://youtube.com/watch?v=" + video.key}>
                            <figure class="relative w-48 aspect-video flex items-center justify-center overflow-hidden rounded-lg">
                                <img 
                                    loading="lazy" 
                                    src={`https://img.youtube.com/vi/${video.key}/sddefault.jpg`} 
                                    class="w-full h-full object-cover brightness-75 transition-all group-hover:brightness-50" 
                                    alt={video.name}
                                />
                                
                                <span class="absolute inset-0 flex items-center justify-center text-white text-3xl">
                                    ▶
                                </span>
                            </figure>
                            
                            <div class="w-48">
                                <p class="font-bold text-sm group-hover:underline group-hover:underline-offset-2 line-clamp-2">
                                    {video.name}
                                </p>
                            </div>
                        </a>
                    ))
                }
            </div>)}
        </section>
        <section class="">
            <h1 class="text-2xl font-black max-md:mx-6">Pictures</h1>
            {error.pics ? <>Error fetching pics data</> : (
            <div class="max-w-6xl overflow-auto flex gap-2 py-2 px-6 md:px-0">
                {
                    pics?.posters?.map((pic: any) => (
                        <a class="flex flex-col gap-2 group cursor-pointer" href={imagesUrl + "w185" + pic.file_path}>
                            <figure class="w-32 overflow-hidden rounded-lg">
                                <img 
                                    loading="lazy" 
                                    src={imagesUrl + "w185" + pic.file_path} 
                                    class="w-full h-full object-cover" 
                                    alt={pic.file_path}
                                    width="185"
                                    height="auto"
                                />
                                
                                
                            </figure>
                        </a>
                    ))
                }
            </div>)}
        </section>

        <section>
		<h1 class="text-2xl font-black max-md:mx-6">Similar {mediaType === "movie" ? "Movies" : "TV Shows"}</h1>
		<article class="max-w-6xl overflow-auto flex gap-2 py-2 px-6 md:px-0">
			{
				error.similar ? <>Error fetching similar movies</> : similar.map((media: any) => (
					<a href={"/details/" + mediaType + "/" + slugify(media.title || media.name) + "-" + media.id} class="group">
						<figure class="w-28 md:w-32">
							<img width="92" height="auto" src={imagesUrl + "w185" + media.poster_path} alt={media.title || media.name} class="w-full h-full object-cover" />
						</figure>
						<div class="text-center mt-2">
						<h3 class="font-bold text-sm group-hover:underline group-hover:underline-offset-2">{media.title || media.name}</h3>
						<p class="text-xs">{media?.release_date ? media.release_date.slice(0,4) : media.first_air_date.slice(0, 4)}</p>
						</div>
					</a>
				))
			}
		</article>
	</section>
        </section>
    </MainLayout>
</AppLayout>