---
import AppLayout from "@/layout/AppLayout.astro";
import MainLayout from "@/layout/MainLayout.astro";
import { getTrendingData, getNowPlayingData } from "@/lib/getData";
import {imagesUrl} from "@/lib/constant";
import type { TTrendingMovies, TTrendingTv } from "@/types";
import {slugify} from "@/lib/helper";

let trendingMovies: TTrendingMovies[] = [];
let trendingTv: TTrendingTv[] = [];
let nowPlayingMovies: TTrendingMovies[] = []
let errors = { movies: null, tv: null, npMovies: null };

const [movieResult, tvResult, npMoviesResult] = await Promise.allSettled([
    getTrendingData({ timeframe: "week", type: "movie" }),
    getTrendingData({ timeframe: "week", type: "tv" }),
	getNowPlayingData()
]);

if (movieResult.status === "fulfilled") {
    trendingMovies = movieResult.value;
} else {
    errors.movies = movieResult.reason.message;
}

if (tvResult.status === "fulfilled") {
    trendingTv = tvResult.value;
} else {
    errors.tv = tvResult.reason.message;
}

if (npMoviesResult.status === "fulfilled") {
    nowPlayingMovies = npMoviesResult.value;
} else {
    errors.npMovies = npMoviesResult.reason.message;
}
---

<AppLayout>
<title slot="head">Movie App</title>
<meta name="description" content="Astro Cloudflare Movie App by Alfath Muqoddas | MovieApp" slot="head"/>
<MainLayout>
	<section class="flex flex-col gap-8 mt-6">
	<section>
		<h1 class="text-xl md:text-3xl font-bold pl-6 md:pl-0">Trending Movies</h1>
		<article class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 py-2 gap-1">
    {
        errors.movies ? <>Error fetching trending movies</> : trendingMovies.slice(0,12).map((movie: any, index: number) => (
            <a 
                class={`
                    ${index === 0 ? "md:col-span-2 md:row-span-2 min-h-75" : "h-auto"} 
                    flex flex-col relative group overflow-hidden
                `} 
                href={"/details/movie/" + slugify(movie.title) + "-" + movie.id}
            >
                <figure class="w-full h-full relative">
                    <img 
                        src={imagesUrl + "w780" + movie.backdrop_path} 
                        alt={movie.title} 
                        class="w-full h-full object-cover"
                        loading={index < 4 ? "eager" : "lazy"}
                    />

                    <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-transparent flex flex-col justify-end p-6 md:p-4">
                        <h2 class={`font-heading uppercase leading-tight text-white ${index === 0 ? "text-xl md:text-3xl" : "text-lg"} group-hover:underline group-hover:underline-offset-2`}>
                            {movie.title}
                        </h2>
                        {index === 0 && (
                            <p class="text-xs text-yellow-400 font-bold">FEATURED RELEASE</p>
                        )}
                    </div>
                </figure>
            </a>
        ))
    }
</article>
	</section>

	<section class="px-6 md:px-0">
		<h1 class="text-xl md:text-3xl font-bold">Trending TV Shows</h1>
		<article class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 mt-2 border-t border-l">
			{
				errors.tv ? <>Error fetching trending tv shows</> : trendingTv.map((tv: any, index: number) => (
					<a href={"/details/tv/" + slugify(tv.name) + "-" + tv.id} class="p-2 border-b border-r border-black group flex items-center gap-2">
						<figure class="basis-1/6 md:basis-1/4 grow-0">
							<img width="92" height="auto" src={imagesUrl + "w92" + tv.poster_path} alt={tv.name} class="w-full h-full object-cover" />
						</figure>
						<div class="basis-5/6 md:basis-3/4 grow-0">
						<h1 class="font-mono">{index + 1}</h1>
						<h3 class="font-bold text-sm group-hover:underline group-hover:underline-offset-2">{tv.name}</h3>
						<p class="text-xs">{tv.first_air_date.slice(0,4)}</p>
						</div>
					</a>
				))
			}
		</article>
	</section>

	<section>
		<h1 class="text-xl md:text-3xl font-bold pl-6 md:pl-0">Now Playing</h1>
		<article class="max-w-6xl overflow-auto flex gap-2 py-2 px-6 md:px-0">
			{
				errors.npMovies ? <>Error fetching now playing movies</> : nowPlayingMovies.map((movie: any) => (
					<a href={"/details/movie/" + slugify(movie.title) + "-" + movie.id} class="group">
						<figure class="w-28 md:w-32">
							<img width="92" height="auto" src={imagesUrl + "w185" + movie.poster_path} alt={movie.title} class="w-full h-full object-cover" />
						</figure>
						<div class="text-center mt-2">
						<h3 class="font-bold text-sm group-hover:underline group-hover:underline-offset-2">{movie.title}</h3>
						<p class="text-xs">{movie.release_date.slice(0,4)}</p>
						</div>
					</a>
				))
			}
		</article>
	</section>
	</section>
</MainLayout>
</AppLayout>